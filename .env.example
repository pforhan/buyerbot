# Slack Configuration
# Get these from https://api.slack.com/apps/
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# LLM Configuration
# Options: mock, ollama
LLM_PROVIDER=mock

# Set this to use Ollama (e.g., llama3)
OLLAMA_MODEL=llama3

# Debug Configuration
# Options: none, basic, full
DEBUG_LEVEL=none
