# --- Slack Configuration ---

# App-Level Token (Required for Socket Mode)
# Starts with 'xapp-'. Used to maintain the websocket connection.
# Found in: App Settings > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# Signing Secret (Required for Multi-Workspace/OAuth)
# Used to verify that requests are actually coming from Slack.
# Found in: App Settings > Basic Information > App Credentials
SLACK_SIGNING_SECRET=...

# --- LLM Provider Configuration ---

# Choose 'mock' for testing without an LLM, or 'ollama' for local LLM support.
LLM_PROVIDER=mock

# --- Ollama Settings (Only needed if LLM_PROVIDER=ollama) ---
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=60

# --- Logging and Debugging ---
# Options: none, basic, full
DEBUG_LEVEL=basic
