# Slack Configuration
# Get these from https://api.slack.com/apps/
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# LLM Configuration
# Options: mock, ollama
LLM_PROVIDER=mock

# Set this to use Ollama (e.g., llama3)
OLLAMA_MODEL=llama3
# Timeout for Ollama API calls in seconds (default 60). Set to 0 to disable.
OLLAMA_TIMEOUT=60

# Debug Configuration
# Options: none, basic, full
DEBUG_LEVEL=none
